

type Uuid = ::six::mcdoc::def::Uuid
type Guuid = ::six::mcdoc::def::Guuid
type PackId = ::slimecore::mcdoc::def::PackId

struct PlayerEntry {
    index: int,
    uuid: Uuid,
    guuid: Guuid,
    username: string,
    data: PlayerData
}

type PlayerArray = [PlayerEntry]

type PlayerData = struct {
	[#[dispatcher_key="pdata:player_data"] string]?: pdata:player_data[[%key]],
}
